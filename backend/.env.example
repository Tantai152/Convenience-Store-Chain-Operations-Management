# Example .env for backend (development/demo)
# Copy this file to `.env` and fill in real values. Do NOT commit real secrets to version control.

# Server
PORT=3001
NODE_ENV=development

# JWT (used by login/auth)
# Use a long random string in production (generate securely).
JWT_SECRET=replace_with_a_strong_random_secret
# Expiration can be values like '1d', '12h', '3600s'
JWT_EXPIRES_IN=1d

# Bcrypt
BCRYPT_SALT_ROUNDS=10

# Admin demo credentials (for presentation/demo only)
# For demo you can use these defaults; change them before any public sharing.
ADMIN_EMAIL=admin@cschain.vn
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=Administrator

# Supabase (used by db/seed.js if you seed data)
# If you use Supabase replace with your project URL and anon/service keys
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
# (Optional) SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Database (if you connect directly to a DB)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=store_chain_db
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Logging
LOG_LEVEL=info